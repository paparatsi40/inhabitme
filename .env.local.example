# Google Maps API Key
# Consigue tu API key en: https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (Email)
RESEND_API_KEY=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Analytics ─────────────────────────────────────────────────────────────────
# Google Analytics 4 — Measurement ID (formato G-XXXXXXXXXX)
# Obtener en: https://analytics.google.com → Admin → Property → Data Streams → Web
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# PostHog — Project API Key + host (US o EU cloud)
# Obtener en: https://posthog.com → Project Settings → Project API Keys
# Host: https://us.i.posthog.com  o  https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — DSN público (cliente) + config para upload de source maps en build
# DSN: Project Settings → Client Keys (DSN)
# Auth token: https://sentry.io/settings/account/api/auth-tokens/ con scopes
#   project:read, project:releases, org:read
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
