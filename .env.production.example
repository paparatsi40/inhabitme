# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# inhabitme - Live Configuration
# ============================================

# -----------------------------
# Application
# -----------------------------
NEXT_PUBLIC_APP_URL=https://inhabitme.com
NODE_ENV=production

# -----------------------------
# Supabase (Production Database)
# -----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# -----------------------------
# Clerk (Production Auth)
# -----------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
CLERK_SECRET_KEY=sk_live_xxxxx

# Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard

# -----------------------------
# Stripe (LIVE MODE - PRODUCTION KEYS) ⚠️
# -----------------------------
STRIPE_SECRET_KEY=sk_live_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# -----------------------------
# Email (Resend - Production)
# -----------------------------
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=InhabitMe <noreply@mail.inhabitme.com>

# -----------------------------
# Cloudinary (Production)
# -----------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dzvp2bg3a
CLOUDINARY_API_KEY=731766425273752
CLOUDINARY_API_SECRET=xxxxx

# -----------------------------
# Internal
# -----------------------------
INTERNAL_ALERT_EMAIL=contact@inhabitme.com

# -----------------------------
# Notes
# -----------------------------
# ⚠️ IMPORTANTE:
# - NUNCA uses test keys (sk_test_*, pk_test_*) en producción
# - NUNCA comitees este archivo a git (.gitignore lo bloquea)
# - Configura estas variables en tu plataforma de hosting (Vercel, etc.)
# - El webhook secret es DIFERENTE entre test y live mode
